# คัดลอกเป็น .env แล้วกรอกค่าจริง (หรือตั้งผ่าน Admin → อีเมล OTP)

MAIL_MODE=auto
MAIL_FROM_NAME=PTS Learning
MAIL_FROM_EMAIL=noreply@thanvasu.com

# ตัวเลือก A: SMTP (Office 365 / Gmail App Password)
SMTP_HOST=smtp.office365.com
SMTP_PORT=587
SMTP_USER=your@thanvasu.com
SMTP_PASS=your-password-or-app-password

# ตัวเลือก B: Brevo API (แนะนำบน cloud)
# BREVO_API_KEY=xkeysib-xxxxxxxx
