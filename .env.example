# คัดลอกเป็น .env แล้วกรอก App Password

MAIL_MODE=smtp
MAIL_FROM_NAME=PTS Learning
MAIL_FROM_EMAIL=businessdev@thanvasu.com

# thanvasu.com = Google Workspace
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=businessdev@thanvasu.com
SMTP_PASS=xxxx xxxx xxxx xxxx

# หรือใช้ Brevo แทน
# BREVO_API_KEY=xkeysib-xxxxxxxx

# —— Google Calendar (แจ้งเตือนวันเรียน) ——
# สร้าง OAuth Client (Web) ที่ Google Cloud Console แล้วเปิด Google Calendar API
APP_BASE_URL=http://localhost:3000
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/api/google/oauth/callback
